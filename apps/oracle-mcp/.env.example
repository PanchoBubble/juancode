# Oracle sidecar config template. Copy to `.env` (gitignored) and fill in.
# A real shell export always wins over `.env`; the file is only a fallback default.

# Telegram bridge (juancode-c6y) — chat with Oracle from Telegram using the same
# backend as the browser console. Unset TELEGRAM_BOT_TOKEN ⇒ bridge disabled.
TELEGRAM_BOT_TOKEN=
# Comma/space-separated numeric Telegram user ids allowed to use the bridge.
# Empty ⇒ every message is ignored.
ALLOWED_USER_IDS=

# Voice notes → text (juancode-lr5). Telegram voice/audio messages are transcribed
# LOCALLY via the `whisper` CLI (openai-whisper) — free, offline, no API key. These
# are optional overrides; defaults assume `whisper` on PATH + the large-v3-turbo model.
# Set JUANCODE_WHISPER_BIN to an absolute path if the sidecar is launched by launchd
# (whose PATH may not include /opt/homebrew/bin).
JUANCODE_WHISPER_BIN=
JUANCODE_WHISPER_MODEL=

# Web Push VAPID contact (juancode-mov). Must be a mailto: or https: URL so push
# services can reach you. Defaults to a neutral placeholder if unset.
VAPID_SUBJECT=
