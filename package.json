{
  "name": "juancode",
  "version": "0.1.0",
  "private": true,
  "description": "A light web harness for running real Claude Code and Codex CLI sessions in the browser, with your MCPs intact.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:server": "pnpm --filter @juancode/server dev",
    "dev:web": "pnpm --filter @juancode/web dev",
    "build": "pnpm --filter \"./apps/*\" build",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "test": "pnpm --recursive --if-present test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "postinstall": "node scripts/fix-node-pty-perms.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "node-pty"]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run --passWithNoTests"
    ],
    "*.{js,jsx,json,css,md,html}": [
      "prettier --write"
    ]
  }
}
